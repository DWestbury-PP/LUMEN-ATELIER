# ── Lumen Atelier ─────────────────────────────────────────────
# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required for
# the studio to create art; everything else has sane defaults.

# Required — the creative ensemble cannot work without it.
ANTHROPIC_API_KEY=

# Optional — lets the Muse ground briefs in real art-history research.
TAVILY_API_KEY=

# The ensemble (override to experiment with different casts)
MUSE_MODEL=claude-haiku-4-5
ARTISAN_MODEL=claude-sonnet-5
CRITIC_MODEL=claude-opus-4-8

# Sign in with Google + commission gating (all optional for local dev;
# without GOOGLE_CLIENT_ID the site is read-only for visitors).
# Create an OAuth "Web application" client at console.cloud.google.com
# and list your gallery origins under Authorized JavaScript origins.
GOOGLE_CLIENT_ID=
# Long random string; sessions reset when it changes (openssl rand -hex 32)
SESSION_SECRET=
# Comma-separated emails auto-granted the admin (curator) role on sign-in
ADMIN_EMAILS=

# Studio behavior
AUTO_CREATE=true                # studio invents its own briefs when idle
AUTO_CREATE_INTERVAL_MIN=45     # minutes between self-directed pieces
MAX_ITERATIONS=4                # revision rounds before the Critic's final ruling
